{
  "name": "outspeed.me",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "bun run --filter '@outspeedme/ingestor' test",
    "lint": "bun run --filter '@outspeedme/ingestor' lint",
    "fmt": "bun run --filter '@outspeedme/ingestor' fmt",
    "format": "bun run fmt",
    "typecheck": "bun run --filter '@outspeedme/ingestor' typecheck",
    "build": "bun run --filter '@outspeedme/ingestor' build",
    "dev": "bun run --elide-lines 0 --filter '@outspeedme/ingestor' dev"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  }
}
